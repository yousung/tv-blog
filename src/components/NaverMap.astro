---
interface Props {
  address: string;
  placeName?: string;
  label?: string;
  lat?: number;
  lng?: number;
}

const { address, placeName, label = '지도', lat, lng } = Astro.props;
const naverApiKey =
  process.env.NAVER_CLIENT_KEY ??
  process.env.PUBLIC_NAVER_CLIENT_KEY ??
  process.env.NAVER_API_KEY ??
  process.env.PUBLIC_NAVER_API_KEY ??
  import.meta.env.NAVER_CLIENT_KEY ??
  import.meta.env.PUBLIC_NAVER_CLIENT_KEY ??
  import.meta.env.NAVER_API_KEY ??
  import.meta.env.PUBLIC_NAVER_API_KEY ??
  '';
const query = [address, placeName].filter(Boolean).join(' ');
const encodedQuery = encodeURIComponent(query);
const mapId = `naver-map-${Math.random().toString(36).slice(2, 10)}`;
const hasCoordinates = typeof lat === 'number' && Number.isFinite(lat) && typeof lng === 'number' && Number.isFinite(lng);
const sdkUrl = naverApiKey
  ? `https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=${encodeURIComponent(naverApiKey)}`
  : '';
---

<section class="naver-map-card" aria-label={`${label} - ${placeName ?? address}`}>
  <div class="map-card-header">
    <div>
      <p class="eyebrow">네이버 지도</p>
      <h2>{placeName ? `${placeName} 위치` : '방송 장소 위치'}</h2>
      <p>{address}</p>
    </div>
    <a class="button" href={`https://map.naver.com/p/search/${encodedQuery}`} target="_blank" rel="noopener">네이버 지도에서 보기</a>
  </div>
  <div
    id={mapId}
    class={`naver-map${naverApiKey && hasCoordinates ? '' : ' naver-map-fallback'}`}
    data-map-id={mapId}
    data-address={address}
    data-place={placeName ?? address}
    data-lat={hasCoordinates ? lat : ''}
    data-lng={hasCoordinates ? lng : ''}
  >
    <p>{naverApiKey && hasCoordinates ? '네이버 지도를 불러오는 중입니다.' : '네이버 지도 표시가 제한되는 환경에서는 상단 버튼으로 위치를 확인해 주세요.'}</p>
  </div>
  {naverApiKey && hasCoordinates && <script is:inline src={sdkUrl}></script>}
  {naverApiKey && hasCoordinates && (
    <script is:inline>
      (() => {
        const currentScript = document.currentScript;
        const container = currentScript?.previousElementSibling?.previousElementSibling;
        if (!container || container.dataset.naverInitialized === 'true') return;
        container.dataset.naverInitialized = 'true';

        const address = container.dataset.address;
        const place = container.dataset.place || address;
        const mapId = container.dataset.mapId;
        const lat = Number(container.dataset.lat);
        const lng = Number(container.dataset.lng);

        function showFallback(message) {
          container.classList.add('naver-map-fallback');
          container.innerHTML = `<p>${message}</p>`;
        }

        function waitForNaverMaps(attempt = 0) {
          if (window.naver?.maps?.Map && window.naver?.maps?.LatLng) {
            initMap(window.naver.maps);
            return;
          }
          if (attempt > 80) {
            showFallback('네이버 지도를 불러오지 못했습니다. 상단 버튼으로 위치를 확인해 주세요.');
            return;
          }
          window.setTimeout(() => waitForNaverMaps(attempt + 1), 100);
        }

        function initMap(maps) {
          if (!mapId || !Number.isFinite(lat) || !Number.isFinite(lng)) {
            showFallback('주소 좌표를 확인한 뒤 네이버 지도에서 위치를 확인해 주세요.');
            return;
          }

          const position = new maps.LatLng(lat, lng);
          container.innerHTML = '';
          const map = new maps.Map(mapId, {
            center: position,
            zoom: 16,
            scaleControl: true,
            logoControl: true,
            mapDataControl: true,
            zoomControl: true,
            zoomControlOptions: { position: maps.Position.TOP_RIGHT }
          });
          const marker = new maps.Marker({ position, map, title: place });
          const infoWindow = new maps.InfoWindow({
            content: `<div class="naver-map-info"><strong>${place}</strong><br>${address}</div>`
          });
          infoWindow.open(map, marker);
        }

        window.navermap_authFailure = () => {
          showFallback('네이버 지도 인증에 실패했습니다. 상단 버튼으로 위치를 확인해 주세요.');
        };
        waitForNaverMaps();
      })();
    </script>
  )}
</section>
