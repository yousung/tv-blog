---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NaverMap from '../../components/NaverMap.astro';
import { CATEGORY_LABELS } from '../../consts';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => post.data.status === 'published')
    .map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;
const displayDate = data.broadcastDate ?? data.date;
const published = displayDate.toISOString();
const modified = published;
const broadcasterFallbackImage = /KBS|2TV|6시 내고향/.test(data.program) ? '/images/broadcast/kbs-2tv-broadcast-note.svg' : undefined;
const heroImage = data.image ?? broadcasterFallbackImage;
const heroImageAlt = data.imageAlt ?? (broadcasterFallbackImage ? `${data.program} 방송 정보 대표 이미지` : data.title);
---

<BaseLayout title={data.title} description={data.description} type="article" publishedTime={published} modifiedTime={modified} tags={data.tags} image={heroImage}>
  <article class="article">
    <header class="article-header">
      <p class="kicker">{CATEGORY_LABELS[data.category]} · {data.program}</p>
      <h1>{data.title}</h1>
      <p class="lead">{data.description}</p>
      <div class="article-meta">
        <time datetime={published}>작성일 {new Intl.DateTimeFormat('ko-KR', { dateStyle: 'long' }).format(displayDate)}</time>
        {data.region && <span>{data.region}</span>}
        {data.placeName && <span>{data.placeName}</span>}
      </div>
      {heroImage && (
        <figure class="article-hero-image">
          <img src={heroImage} alt={heroImageAlt} loading="eager" decoding="async" />
          {heroImageAlt && <figcaption>{heroImageAlt}</figcaption>}
        </figure>
      )}
    </header>
    <div class="notice">
      이 글은 방송 내용과 공개 자료를 바탕으로 정리한 정보입니다. 방문 전 영업시간, 가격, 휴무는 공식 채널이나 지도로 다시 확인하세요.
    </div>
    {data.address && (data.category === 'food' || data.category === 'local') && (
      <NaverMap address={data.address} placeName={data.placeName} label="방송 맛집 지도" lat={data.mapLat} lng={data.mapLng} />
    )}
    <div class="article-body">
      <Content />
    </div>
    {data.source.length > 0 && (
      <section class="article-sources">
        <h2>출처 및 확인 자료</h2>
        <ul>{data.source.map((item) => <li>{item}</li>)}</ul>
      </section>
    )}
  </article>
</BaseLayout>
